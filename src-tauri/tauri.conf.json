{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kiwi",
  "version": "0.1.0",
  "identifier": "com.nest.kiwi",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": { "script": "npm run dev", "cwd": "../ui" },
    "beforeBuildCommand": { "script": "npm run build", "cwd": "../ui" }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kiwi",
        "width": 1280,
        "height": 860,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
