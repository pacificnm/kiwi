# Example knowledge base config for `kiwi-mcp-memory --index-kb --kb-config`.
#
# Copy or generate via:
#   ./scripts/index-knowledge.sh
#
# Override the download location:
#   KIWI_KNOWLEDGE=~/kiwi-knowledge ./scripts/index-knowledge.sh

[[collections]]
name = "rust-book"
source = "/home/USER/kiwi-knowledge/rust/rust-book/src"
extensions = ["md"]

[[collections]]
name = "rust-by-example"
source = "/home/USER/kiwi-knowledge/rust/rust-by-example/src"
extensions = ["md"]

[[collections]]
name = "rust-reference"
source = "/home/USER/kiwi-knowledge/rust/rust-reference/src"
extensions = ["md"]

[[collections]]
name = "egui"
source = "/home/USER/kiwi-knowledge/egui/crates/egui/src"
extensions = ["rs", "md"]

[[collections]]
name = "eframe"
source = "/home/USER/kiwi-knowledge/egui/crates/eframe/src"
extensions = ["rs", "md"]

[[collections]]
name = "egui-docs"
source = "/home/USER/kiwi-knowledge/egui/docs"
extensions = ["md"]
